// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  DISPATCHER
  DRIVER
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
}

enum VehicleType {
  BUS
  MINIBUS
  VAN
  TRUCK
  CAR
  OTHER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  IN_MAINTENANCE
  RETIRED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
  TIRE
  OIL_CHANGE
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  INSURANCE
  TOLL
  PARKING
  SALARY
  OFFICE
  OTHER
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())

  // Relations
  users              User[]
  drivers            Driver[]
  vehicles           Vehicle[]
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
  settings_records   Settings[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(DRIVER)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driver       Driver?
  expenses     Expense[]    @relation("CreatedByUser")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Driver {
  id             String       @id @default(cuid())
  name           String
  email          String?      @unique
  phone          String?
  licenseNumber  String       @unique
  status         DriverStatus @default(ACTIVE)
  organizationId String
  userId         String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  trips        Trip[]
  fuelLogs     FuelLog[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("drivers")
}

model Vehicle {
  id             String        @id @default(cuid())
  plateNumber    String        @unique
  make           String
  model          String
  year           Int
  type           VehicleType   @default(OTHER)
  status         VehicleStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("vehicles")
}

model Trip {
  id             String     @id @default(cuid())
  vehicleId      String
  driverId       String
  origin         String
  destination    String
  distanceKm     Float?
  startTime      DateTime
  endTime        DateTime?
  status         TripStatus @default(SCHEDULED)
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver       Driver       @relation(fields: [driverId], references: [id], onDelete: Restrict)
  expenses     Expense[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceRecord {
  id             String            @id @default(cuid())
  vehicleId      String
  type           MaintenanceType   @default(OTHER)
  description    String
  scheduledAt    DateTime
  completedAt    DateTime?
  costAmount     Float?
  status         MaintenanceStatus @default(SCHEDULED)
  organizationId String
  createdAt      DateTime          @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([vehicleId])
  @@map("maintenance_records")
}

model FuelLog {
  id             String   @id @default(cuid())
  vehicleId      String
  driverId       String?
  liters         Float
  costPerLiter   Float
  totalCost      Float
  odometerKm     Float?
  station        String?
  organizationId String
  createdAt      DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver       Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([vehicleId])
  @@map("fuel_logs")
}

model Expense {
  id             String          @id @default(cuid())
  category       ExpenseCategory @default(OTHER)
  amount         Float
  description    String
  date           DateTime        @default(now())
  vehicleId      String?
  tripId         String?
  organizationId String
  createdBy      String
  createdAt      DateTime        @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trip         Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  creator      User         @relation("CreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([organizationId, category])
  @@map("expenses")
}

model Settings {
  id             String @id @default(cuid())
  organizationId String
  key            String
  value          Json

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("settings")
}
