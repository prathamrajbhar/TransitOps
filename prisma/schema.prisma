// ─── TransitOps Prisma Schema ─────────────────────────────
// Aligned with Frontend MockDataContext types so the UI
// can be wired to the real backend API.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  MINI
  BUS
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum LicenseCategory {
  LMV
  HMV
  OTHER
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())

  users              User[]
  drivers            Driver[]
  vehicles           Vehicle[]
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
  settings_records   Settings[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(DISPATCHER)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips        Trip[]       @relation("CreatedByUser")
  expenses     Expense[]    @relation("CreatedByUser")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Driver {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  licenseNo       String         @unique
  licenseCategory LicenseCategory @default(LMV)
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Int            @default(100)
  status          DriverStatus   @default(AVAILABLE)
  organizationId  String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips        Trip[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("drivers")
}

model Vehicle {
  id                String        @id @default(cuid())
  registrationNo    String        @unique
  nameModel         String
  type              VehicleType   @default(VAN)
  maxLoadCapacityKg Float
  odometerKm        Float         @default(0)
  acquisitionCost   Float         @default(0)
  region            String        @default("West")
  status            VehicleStatus @default(AVAILABLE)
  organizationId    String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("vehicles")
}

model Trip {
  id                String     @id @default(cuid())
  tripCode          String
  source            String
  destination       String
  vehicleId         String?
  driverId          String?
  cargoWeightKg     Float
  plannedDistanceKm Float
  actualDistanceKm  Float?
  finalOdometerKm   Float?
  fuelConsumedL     Float?
  status            TripStatus @default(DRAFT)
  etaMinutes        Int?
  createdById       String
  organizationId    String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver       Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  creator      User         @relation("CreatedByUser", fields: [createdById], references: [id], onDelete: Restrict)
  expenses     Expense[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceRecord {
  id              String            @id @default(cuid())
  vehicleId       String
  serviceType     String
  cost            Float
  serviceDate     DateTime
  status          MaintenanceStatus @default(ACTIVE)
  organizationId  String
  createdAt       DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([vehicleId])
  @@map("maintenance_records")
}

model FuelLog {
  id             String   @id @default(cuid())
  vehicleId      String
  date           DateTime @default(now())
  liters         Float
  cost           Float
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([vehicleId])
  @@map("fuel_logs")
}

model Expense {
  id                String   @id @default(cuid())
  tripId            String?
  vehicleId         String?
  toll              Float    @default(0)
  other             Float    @default(0)
  maintenanceLinked Float    @default(0)
  total             Float    @default(0)
  organizationId    String
  createdBy         String
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trip         Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  creator      User         @relation("CreatedByUser", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([tripId])
  @@map("expenses")
}

model Settings {
  id             String @id @default(cuid())
  organizationId String
  key            String
  value          Json

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("settings")
}
